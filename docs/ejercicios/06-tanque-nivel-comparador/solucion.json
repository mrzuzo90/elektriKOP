            { "kind": "contact", "id": "n7", "addr": "M0.0", "neg": false },
            { "kind": "compare", "id": "n8", "addr": "IW0", "op": "<", "value": 30 }
          ],
          "outAddr": "Q0.0",
          "outType": "coil",
          "preset": 2
        },
        {
          "id": 2,
          "title": "ALARMA_NIVEL_ALTO",
