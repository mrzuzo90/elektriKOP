            },
            { "kind": "contact", "id": "n6", "addr": "I0.1", "neg": true }
          ],
          "outAddr": "M0.0",
          "outType": "coil",
          "preset": 2
        },
        {
          "id": 1,
          "title": "BOMBA_LLENADO",
          "comment": "Llena el tanque mientras el sistema esté activo y el nivel esté por debajo del 30%.",
